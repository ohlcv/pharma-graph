# 药学知识图谱 — 环境变量示例
# 复制此文件为 .env 并填入实际值
# .env 文件不应提交到仓库（已加入 .gitignore）

# content/ 目录路径（相对于项目根）
CONTENT_PATH=./content

# 图谱数据输出路径（相对于项目根）
OUTPUT_PATH=./dist/graph-data.json

# 开发服务器端口
PORT=3000

# 构建模式：development | production
NODE_ENV=development

# 知识库路径（用于多图谱切换时指定不同的 content 目录）
GRAPH_NAME=pharma-graph
