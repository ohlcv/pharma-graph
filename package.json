    "glob": "^11.0.0",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22.0.0",
    "autoprefixer": "^10.5.0",
    "cytoscape-cose-bilkent": "^4.1.0",
    "cytoscape-dagre": "^4.0.0",
    "cytoscape-euler": "^1.2.4",
    "cytoscape-popper": "^4.0.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^5.5.0",
    "vite": "^8.0.16"
  }
